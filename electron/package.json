{
  "name": "starpeace-online",
  "version": "1.1.0-beta",
  "productName": "Starpeace Online",
  "description": "Starpeace Online — Desktop Client",
  "author": "Starpeace Online Contributors",
  "homepage": "https://starpeaceonline.com",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Crazysky/SPO-WebClient.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "node launch.js",
    "dist": "node dist.js"
  },
  "build": {
    "appId": "com.starpeaceonline.client",
    "productName": "Starpeace Online",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/server-bundle.js",
        "to": "dist/server-bundle.js"
      },
      {
        "from": "../public",
        "to": "public"
      }
    ],
    "asarUnpack": [
      "**/7zip-min/**",
      "**/7zip-bin/**"
    ],
    "publish": {
      "provider": "github",
      "releaseType": "prerelease"
    },
    "generateUpdatesFilesForAllChannels": true,
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Starpeace Online",
      "differentialPackage": true
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": "dmg"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "7zip-min": "^2.1.0",
    "electron-updater": "^6.8.3"
  }
}
