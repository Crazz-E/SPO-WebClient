# SPO-WebClient Production Environment
# Copy to project root as .env and chmod 600

NODE_ENV=production
PORT=8080

# Game server directory (official SPO servers)
RDO_DIR_HOST=www.starpeaceonline.com

# Terrain/object asset CDN (Cloudflare R2)
CHUNK_CDN_URL=https://spo.zz.works

# Logging: debug | info | warn | error
# WARNING: debug level may log session IDs — use info in production
LOG_LEVEL=info
# NDJSON structured log file (persisted via volume mount in docker-compose)
LOG_FILE=logs/gateway.ndjson
LOG_JSON=true

# Required when behind nginx reverse proxy (correct IP for rate limiting)
TRUST_PROXY=true

# Enable HSTS header (only set true when serving over HTTPS)
ENABLE_HSTS=true

# Comma-separated GM usernames for broadcast chat (optional)
SPO_GM_USERS=

# Force all players into a specific world (test phase, optional)
# Format: zoneId/worldName — zones: beta, free, restricted
# Example: beta/Shamba
# Remove or leave empty to restore normal zone/world selection
SPO_FORCE_WORLD=

# ── Cache Sync Service ──────────────────────────────────────────────
# Cache sync mode: 'inline' (default, in-process) or 'external' (separate container)
# Set to 'external' in docker-compose when using spo-cache-sync sidecar
CACHE_SYNC_MODE=external

# Re-sync interval in ms (default: 3600000 = 1 hour). Only used by spo-cache-sync container.
CACHE_SYNC_INTERVAL_MS=3600000

# Set to 'true' to exit after first sync (useful for CI/init containers)
# CACHE_SYNC_ONCE=false
