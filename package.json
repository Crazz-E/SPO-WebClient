{
  "name": "starpeace-online-client",
  "version": "1.0.1-beta",
  "description": "TypeScript web client for Starpeace Online - A browser-based multiplayer tycoon/simulation game",
  "main": "dist/electron/main.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:terrain-test": "esbuild src/client/terrain-test.ts --bundle --outfile=public/terrain-test.js --format=iife",
    "build": "npm run build:server && npm run build:client && npm run build:terrain-test",
    "start": "node --disable-warning=DEP0040 dist/server/server.js",
    "dev": "npm run build && npm start",
    "dev:react": "vite",
    "dev:electron": "npm run build && npm run build:electron && electron .",
    "dist": "npm run build && npm run build:electron && electron-builder",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:changed": "jest --onlyChanged --bail",
    "test:smoke": "jest --selectProjects component --bail",
    "release": "node scripts/release.js"
  },
  "keywords": [
    "starpeace",
    "online",
    "game",
    "multiplayer",
    "tycoon",
    "simulation",
    "websocket",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Crazysky/SPO-WebClient/starpeace-online-client.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "7zip-min": "^2.1.0",
    "cheerio": "^1.1.2",
    "gifuct-js": "^2.1.2",
    "lucide-react": "^0.575.0",
    "node-fetch": "^2.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "electron-updater": "^6.8.3",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.9",
    "@types/node-fetch": "^2.6.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
