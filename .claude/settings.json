{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit && npx tsc --noEmit -p tsconfig.client.json",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git restore*)",
      "Bash(git stash*)",
      "Bash(git tag*)",
      "Bash(git remote*)",
      "Bash(git config*)",
      "Bash(git blame*)",
      "Bash(git grep*)",
      "Bash(git ls-files*)",
      "Bash(git ls-tree*)",
      "Bash(git rev-parse*)",
      "Bash(git describe*)",
      "Bash(git cherry-pick*)",
      "Bash(git apply*)",
      "Bash(git format-patch*)",
      "Bash(git am*)",
      "Bash(git bisect*)",
      "Bash(git submodule*)",
      "Bash(git worktree*)",
      "Bash(git reflog*)",
      "Bash(git reset*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd *)",
      "Bash(cd *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(powershell*Get-Content*SPO-Original*)",
      "Bash(powershell*Get-ChildItem*SPO-Original*)",
      "Bash(powershell*Select-String*SPO-Original*)",
      "Bash(powershell*Test-Path*SPO-Original*)",
      "Bash(powershell.exe*Get-Content*SPO-Original*)",
      "Bash(powershell.exe*Get-ChildItem*SPO-Original*)",
      "Bash(powershell.exe*Select-String*SPO-Original*)",
      "Bash(powershell.exe*Test-Path*SPO-Original*)",
      "Bash(cmd.exe*type*SPO-Original*)",
      "Bash(cmd.exe*dir*SPO-Original*)",
      "Bash(cmd.exe*findstr*SPO-Original*)"
    ],
    "deny": [
      "Bash(git clean*)",
      "Bash(git rm -rf*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git gc --prune*)",
      "Bash(git prune*)",
      "Bash(git reflog expire*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)"
    ]
  }
}
